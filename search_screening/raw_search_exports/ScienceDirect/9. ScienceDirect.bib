@article{MIMCHE2026110836,
title = {Optimization of biogas production through codigestion of water hyacinth - cow dung: Experimental evaluation kinetic modeling and economic feasibility},
journal = {Results in Engineering},
volume = {30},
pages = {110836},
year = {2026},
issn = {2590-1230},
doi = {https://doi.org/10.1016/j.rineng.2026.110836},
url = {https://www.sciencedirect.com/science/article/pii/S2590123026018694},
author = {Abdel Aziz Mfondoun Mimche and Paul Edouard Duclair Pountounynyi and Cyrille Fotsing Talla and Ghislain Junior {Bangoup Ntegmi} and Jean Luc Nsouandele and Aurélien {Kenfack Jiotsa}},
keywords = {Co-digestion, Water hyacinth, Cow dung, Biogas, Kinetics},
abstract = {Water hyacinth (WH) is an invasive species that negatively impacts aquatic environments but possesses a suitable C/N ratio and pH for anaerobic digestion. Co-digestion with cow dung (CD) can optimize biogas production; however, challenges remain in determining the optimal mixing ratios, modeling production kinetics, and assessing economic viability. This study evaluates the biogas production potential of co-digesting water hyacinth (Eichhornia crassipes) and cow dung, models the production kinetics, and analyzes techno-economic feasibility. Five 20 L anaerobic reactors (R1–R5) were used with varying substrate ratios. Peak of biogas production (173.90 ± 0.18 mL/g VS) was achieved with 45% water hyacinth and 55% cow dung. The Richards model showed the best correlation with experimental results (0.920 ≤ R² ≤ 0.999). Economic analysis indicated that an initial investment of 18,000,000 FCFA yields a net present value of 6815,347 FCFA, with a payback period of approximately 6.18 years and an internal rate of return of 15.25%. This study underscores the importance of cow dung proportions in maximizing methane production and provides insights for sustainable organic waste valorization.}
}